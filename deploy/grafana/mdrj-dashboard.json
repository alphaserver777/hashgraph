      "targets": [
        {
          "expr": "mdrj_db_size_bytes",
          "legendFormat": "{{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Сетевая стоимость на событие (bytes/event)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 26},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [
        {
          "expr": "mdrj_bytes_per_event",
